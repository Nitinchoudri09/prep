# ─────────────────────────────────────────────────────────────────────────────
# HirePilot — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# Django Security
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# Email Configuration (for Forgot Password feature)
# ─────────────────────────────────────────────────────────────────────────────
# Gmail SMTP setup:
# 1. Go to your Google Account → Security → 2-Step Verification → App Passwords
# 2. Generate an App Password for "Mail" → "Windows Computer" (or Other)
# 3. Use that 16-character app password as EMAIL_HOST_PASSWORD (NOT your Google password)

EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-16-char-gmail-app-password

# Branded sender name (shown in the recipient's inbox)
DEFAULT_FROM_EMAIL=HirePilot <your-gmail@gmail.com>

# ─────────────────────────────────────────────────────────────────────────────
# Database (optional — uses SQLite if not set)
# ─────────────────────────────────────────────────────────────────────────────
# DATABASE_URL=postgres://user:password@host:5432/dbname
